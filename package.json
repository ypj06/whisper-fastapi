{
  "name": "youtube-knowledge-extractor",
  "version": "1.0.0",
  "private": true,
  "description": "YouTube video to Chinese dialogue article generator powered by Gemini, deployed on Cloudflare Workers.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "dev:my": "wrangler dev --config wrangler.local.toml",
    "deploy:my": "wrangler deploy --config wrangler.local.toml",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251001.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "hono": "^4.6.14"
  }
}
